{
  "name": "liberation-os",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "worker": "pnpm --filter @liberation-os/worker dev",
    "db:generate": "pnpm --filter @liberation-os/db prisma:generate",
    "db:migrate": "pnpm --filter @liberation-os/db prisma:migrate"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.2",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3"
  }
}